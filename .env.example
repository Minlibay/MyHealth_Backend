# Скопируй в .env и заполни реальными значениями (НЕ коммить .env).
POSTGRES_DB=myhealth
POSTGRES_USER=myhealth
# Сильный пароль БД:
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Секрет подписи JWT — минимум 32 случайных байта.
# Сгенерировать: openssl rand -base64 48
JWT_KEY=CHANGE_ME_base64_secret_min_32_bytes
JWT_ISSUER=MyHealth
JWT_AUDIENCE=MyHealth
